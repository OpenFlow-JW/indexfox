{
  "name": "indexfox",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "description": "Local-first doc scout: find knowledge, workflows, and co-author skills from messy folders.",
  "bin": {
    "indexfox": "./bin/indexfox.mjs"
  },
  "scripts": {
    "start": "node ./bin/indexfox.mjs",
    "serve": "node ./bin/indexfox.mjs serve",
    "scan": "node ./bin/indexfox.mjs scan --path ./",
    "harness": "node ./harness/run.mjs",
    "harness:ui": "node ./harness/ui_smoke.mjs",
    "lint": "node -c ./bin/indexfox.mjs"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1"
  }
}
